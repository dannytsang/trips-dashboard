# Trips Dashboard — local environment template.
#
# Copy to .env.local for local dev (Next.js auto-loads .env.local).
# For Vercel: set the same names in Project → Settings → Environment Variables,
# then redeploy. Vercel does NOT hot-reload env changes.
#
# All NEXT_PUBLIC_* vars are inlined into the client bundle by Next.js, so
# the values will be visible to anyone who opens DevTools on a deployed page.
# Do NOT put server secrets in NEXT_PUBLIC_* vars.

# ----- Map provider switch (spec 010 FR-009, FR-027) -----
# Default: unset (or "osm") — uses embedded OpenStreetMap, no key required.
# Set to "google" to switch the trip detail map to Google Maps Embed API.
# You must also set NEXT_PUBLIC_GMAPS_EMBED_KEY below; without a key the
# dashboard silently falls back to OSM so preview deploys never break.
NEXT_PUBLIC_GMAPS_PROVIDER=

# Google Maps Embed API key. Get one from
# https://console.cloud.google.com/google/maps-apis/credentials
# Enable "Maps Embed API" on the project, then restrict the key by HTTP
# referrer to:
#   - tsang-travel.vercel.app/*
#   - *.vercel.app/*        (preview deploys)
# This is a browser-side iframe key, so it MUST live in NEXT_PUBLIC_*.
# Restricting by HTTP referrer is what stops someone lifting the key and
# using it from their own site.
NEXT_PUBLIC_GMAPS_EMBED_KEY=
