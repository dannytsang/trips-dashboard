{
  "name": "trips-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "test": "node scripts/check-oidc-source.mjs && node scripts/check-blob-storage.mjs && node scripts/check-dashboard-polish.mjs",
    "scan:static-private-data": "node scripts/scan-static-private-data.cjs",
