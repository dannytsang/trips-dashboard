    "vercel:ignore-build": "bash scripts/vercel-ignore-build.sh"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "next": "15.5.19",
    "next-auth": "^4.24.14",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  }
}
